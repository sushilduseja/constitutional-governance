# Groq API key for the interpreter LLM (REQUIRED)
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Monitored LLM configuration (which model the service calls for /evaluate)
# Provider: anthropic, openai, or groq
MONITORED_PROVIDER=anthropic
MONITORED_MODEL=governance-alpha-7b

# API keys for monitored LLM providers (required only if using that provider)
# Get Anthropic key at: https://console.anthropic.com/
# Get OpenAI key at: https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
