# Groq API key for the interpreter LLM
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Monitored LLM configuration (which model the service calls for /evaluate)
# Provider: anthropic, openai, or groq
MONITORED_PROVIDER=anthropic
MONITORED_MODEL=claude-3-5-sonnet-20241022

# API keys for monitored LLM providers (if not already set)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
